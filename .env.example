# Credenciais públicas da instância Supabase (nunca use a service_role key aqui).
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
# Chave publishable (formato novo, sb_publishable_...). A chave anon legada
# também é aceita via VITE_SUPABASE_ANON_KEY.
VITE_SUPABASE_PUBLISHABLE_KEY=sua-chave-publishable

# OAuth do Google (escopo drive.file) para a sincronização de planilhas. O
# Client ID é público; o Client Secret fica só no backend (segredos do
# Supabase). Cadastre como Redirect URI autorizado:
# http://localhost:5173/google/callback e a URL de produção equivalente
# (ex.: https://mesusp.netlify.app/google/callback).
VITE_GOOGLE_CLIENT_ID=seu-client-id.apps.googleusercontent.com

# Chave de API do Google (Picker API habilitada) usada pelo Google Picker para
# escolher a planilha. É pública; restrinja-a por referrer HTTP no Google Cloud.
VITE_GOOGLE_API_KEY=sua-api-key
