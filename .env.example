# Credenciais públicas da instância Supabase (nunca use a service_role key aqui).
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
# Chave publishable (formato novo, sb_publishable_...). A chave anon legada
# também é aceita via VITE_SUPABASE_ANON_KEY.
VITE_SUPABASE_PUBLISHABLE_KEY=sua-chave-publishable
